#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOG_MODE="all"
ENABLE_LOG=1
DRY_RUN=0
LOGGER_PID=""

usage() {
  cat <<'USAGE'
用法：./dev [选项]

作用：
  以接近 `pnpm dev` 的方式启动 DevHaven 原生开发态：
  先构建 React WebUI 资源并确保 Ghostty / Sparkle vendor 可用，
  再按需接入 unified log，最后运行 `swift run --package-path macos DevHavenApp`。

选项：
  --dry-run               只打印将要执行的命令，不真正启动
  --no-log                不启动 unified log 观察
  --logs all|app|ghostty  控制日志范围（默认：all）
  --help                  显示帮助

示例：
  ./dev
  ./dev --logs app
  ./dev --no-log
  ./dev --dry-run
USAGE
}

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

build_predicate() {
  case "$LOG_MODE" in
    all)
      printf 'subsystem == "DevHavenNative" || subsystem == "com.mitchellh.ghostty"\n'
      ;;
    app)
      printf 'subsystem == "DevHavenNative"\n'
      ;;
    ghostty)
      printf 'subsystem == "com.mitchellh.ghostty"\n'
      ;;
    *)
      fail "--logs 仅支持 all、app、ghostty"
      ;;
  esac
}

print_command() {
  local label="$1"
  shift
  printf '%s: ' "$label"
  printf '%s' "$1"
  shift || true
  for arg in "$@"; do
    printf ' %s' "$arg"
  done
  printf '\n'
}

cleanup() {
  local exit_code=$?
  if [[ -n "$LOGGER_PID" ]] && kill -0 "$LOGGER_PID" 2>/dev/null; then
    kill "$LOGGER_PID" 2>/dev/null || true
    wait "$LOGGER_PID" 2>/dev/null || true
  fi
  exit "$exit_code"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --no-log)
      ENABLE_LOG=0
      shift
      ;;
    --logs)
      [[ $# -ge 2 ]] || fail "--logs 需要参数"
      LOG_MODE="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      fail "未知参数：$1"
      ;;
  esac
done

cd "$ROOT_DIR"

VENDOR_COMMANDS=(
  "bash macos/scripts/setup-ghostty-framework.sh --ensure-worktree-vendor"
  "bash macos/scripts/setup-sparkle-framework.sh --ensure-worktree-vendor"
)
WEBUI_BUILD_COMMAND=(bash macos/scripts/build-run-configuration-webui.sh)
CLI_BUILD_COMMAND=(swift build --package-path macos --product DevHavenCLI)
RUN_COMMAND=(swift run --package-path macos DevHavenApp)
LOG_PREDICATE="$(build_predicate)"
LOG_COMMAND=(log stream --style compact --level debug --predicate "$LOG_PREDICATE")

if (( DRY_RUN )); then
  print_command "React WebUI构建命令" "${WEBUI_BUILD_COMMAND[@]}"
  for command in "${VENDOR_COMMANDS[@]}"; do
    read -r -a parsed_command <<< "$command"
    print_command "vendor命令" "${parsed_command[@]}"
  done
  print_command "CLI构建命令" "${CLI_BUILD_COMMAND[@]}"
  if (( ENABLE_LOG )); then
    print_command "日志命令" "${LOG_COMMAND[@]}"
  fi
  print_command "启动命令" "${RUN_COMMAND[@]}"
  exit 0
fi

command -v swift >/dev/null 2>&1 || fail "未检测到 swift，请先安装 Xcode 或 Command Line Tools"
command -v log >/dev/null 2>&1 || fail "未检测到 macOS log 命令"

trap cleanup EXIT INT TERM

printf '==> 构建 Run Configuration React WebUI\n'
"${WEBUI_BUILD_COMMAND[@]}"

printf '==> 确保 Ghostty / Sparkle vendor 可用\n'
for command in "${VENDOR_COMMANDS[@]}"; do
  eval "$command"
done

printf '==> 构建 DevHavenCLI helper\n'
"${CLI_BUILD_COMMAND[@]}"

if (( ENABLE_LOG )); then
  printf '==> 启动 unified log 观察（logs=%s）\n' "$LOG_MODE"
  "${LOG_COMMAND[@]}" &
  LOGGER_PID=$!
fi

printf '==> 启动 DevHaven 原生应用\n'
"${RUN_COMMAND[@]}"
